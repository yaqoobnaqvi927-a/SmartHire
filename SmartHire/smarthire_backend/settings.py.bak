# ═══════════════════════════════════════════════════
# GEMINI API KEY
# ═══════════════════════════════════════════════════
GEMINI_API_KEY = os.environ.get('GEMINI_API_KEY', '')

if not GEMINI_API_KEY:
    import warnings
    warnings.warn(
        "[WARNING] GEMINI_API_KEY is not set. CV parsing and AI features will use fallback regex.",
        RuntimeWarning
    )
else:
    print(f"[OK] Gemini API key loaded ({GEMINI_API_KEY[:8]}...{GEMINI_API_KEY[-4:]})")
