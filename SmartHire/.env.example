# SmartHire — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the real .env to version control.

# ── Django Core ───────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-here
DEBUG=True
DJANGO_SETTINGS_MODULE=smarthire_backend.settings.development

# ── Database ──────────────────────────────────────────────────────────────────
# Used by production.py via dj-database-url; ignored in development (SQLite used)
DATABASE_URL=postgresql://user:password@localhost:5432/smarthire_db

# ── Google Gemini AI ──────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-key

# ── AWS S3 (Media Storage — production only) ──────────────────────────────────
AWS_ACCESS_KEY_ID=your-key
AWS_SECRET_ACCESS_KEY=your-secret
AWS_STORAGE_BUCKET_NAME=smarthire-prod-bucket
AWS_S3_REGION_NAME=us-east-1

# ── Zoom Video Interviews ─────────────────────────────────────────────────────
ZOOM_ACCOUNT_ID=your-zoom-account-id
ZOOM_CLIENT_ID=your-zoom-client-id
ZOOM_CLIENT_SECRET=your-zoom-client-secret

# ── Firebase Cloud Messaging ──────────────────────────────────────────────────
FIREBASE_SERVICE_ACCOUNT_PATH=/app/secrets/firebase-service-account.json

# ── CORS (production only) ────────────────────────────────────────────────────
FRONTEND_URL=https://smarthire.example.com
