# SmartHire — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the real .env to version control.

# ── Django Core ───────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=your-secret-key-here-change-this-to-50-random-chars
DEBUG=True
DJANGO_SETTINGS_MODULE=smarthire_backend.settings.development
ALLOWED_HOSTS=127.0.0.1,localhost,10.0.2.2,*

# ── Database ──────────────────────────────────────────────────────────────────
# Option 1: Single URL (preferred for production)
DATABASE_URL=postgresql://smarthire_user:password@localhost:5432/smarthire_db

# Option 2: Individual vars (Docker Compose pattern)
DB_NAME=smarthire_db
DB_USER=smarthire_user
DB_PASSWORD=your-db-password
DB_HOST=db
DB_PORT=5432

# ── Google Gemini AI ──────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key

# ── AWS S3 (Media Storage — production only) ──────────────────────────────────
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_STORAGE_BUCKET_NAME=smarthire-cvs
AWS_S3_REGION_NAME=ap-south-1

# ── Zoom Video Interviews ─────────────────────────────────────────────────────
ZOOM_ACCOUNT_ID=your-zoom-account-id
ZOOM_CLIENT_ID=your-zoom-client-id
ZOOM_CLIENT_SECRET=your-zoom-client-secret

# ── Firebase Cloud Messaging ──────────────────────────────────────────────────
FIREBASE_SERVICE_ACCOUNT_PATH=/app/secrets/firebase-service-account.json

# ── Google Calendar ───────────────────────────────────────────────────────────
GOOGLE_CALENDAR_SERVICE_ACCOUNT_PATH=/app/secrets/firebase-service-account.json

# ── Email (SMTP — production only) ────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@smarthire.app

# ── CORS (production only — comma-separated origins) ──────────────────────────
CORS_ALLOWED_ORIGINS=https://smarthire.yourdomain.com
